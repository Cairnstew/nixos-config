# Local .terraform directories
.terraform/

# Terraform state files (VERY sensitive)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Lock file (optional — see note below)
# .terraform.lock.hcl

# Plan output files
*.tfplan

# Editor / OS junk
.DS_Store
Thumbs.db