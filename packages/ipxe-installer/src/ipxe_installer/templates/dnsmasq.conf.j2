# dnsmasq config generated by ipxe-installer
port=0
interface={{ interface }}
bind-interfaces
dhcp-range={{ dhcp_range_start }},{{ dhcp_range_end }},{{ dhcp_lease_time }}
dhcp-option=3,{{ server_address }}
dhcp-option=6,{{ server_address }}
enable-tftp
tftp-root={{ tftp_root }}
# BIOS PXE
dhcp-boot=undionly.kpxe
# UEFI x86_64
dhcp-match=set:efi-x86_64,option:client-arch,7
dhcp-boot=tag:efi-x86_64,ipxe.efi
# iPXE already loaded — chain to HTTP
dhcp-match=set:ipxe,175
dhcp-boot=tag:ipxe,http://{{ server_address }}/boot.ipxe
# Logging
log-dhcp
log-facility=-
