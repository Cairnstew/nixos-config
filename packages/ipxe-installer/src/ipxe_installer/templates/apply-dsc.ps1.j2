# DSC v3 bootstrap — generated by ipxe-installer
# Downloads DSC and applies configuration at first logon

$ProgressPreference = 'SilentlyContinue'
$ErrorActionPreference = 'Stop'

Write-Host "=== DSC v3 Bootstrap ==="

# Configuration
$dscVersion = "3.0.0-preview.5"
$dscUrl = "https://github.com/PowerShell/DSC/releases/download/v$dscVersion/"
$dscZip = "DSC-$dscVersion-win-x64.zip"
$dscDir = "$env:ProgramFiles\DSC"

# Configuration YAML (generated)
$configYaml = @'
{{ dsc_config_yaml }}
'@

Write-Host "Downloading DSC v3..."
$wc = New-Object System.Net.WebClient
$wc.DownloadFile("$dscUrl$dscZip", "$env:TEMP\$dscZip")

Write-Host "Extracting DSC..."
Expand-Archive -Path "$env:TEMP\$dscZip" -DestinationPath "$dscDir" -Force

Write-Host "Writing configuration..."
$configYaml | Out-File -FilePath "$dscDir\config.dsc.yaml" -Encoding utf8

Write-Host "Applying configuration..."
& "$dscDir\dsc.exe" config set --path "$dscDir\config.dsc.yaml"

Write-Host "=== DSC Bootstrap Complete ==="
