#!ipxe
echo "=== Stage: {{ stage_name|capitalize }} ({{ profile_name }}) ==="
{% if stage_name == "nixos" %}
echo "Booting NixOS netboot installer..."
kernel http://{{ server_address }}/machines/{{ mac }}/vmlinuz pxe.server={{ server_address }} pxe.mac={{ mac }} pxe.logport=8081 nousb console=tty0 console=ttyS0,115200n8 ip=dhcp
initrd http://{{ server_address }}/machines/{{ mac }}/initrd
boot
{% elif stage_name == "windows" %}
kernel wimboot
initrd http://{{ server_address }}/machines/{{ mac }}/autounattend.xml  autounattend.xml
initrd http://{{ server_address }}/windows/boot/bcd         BCD
initrd http://{{ server_address }}/windows/boot/boot.sdi    boot.sdi
initrd http://{{ server_address }}/windows/sources/boot.wim boot.wim
boot
{% elif stage_name == "done" %}
echo "Installation complete — booting from local disk"
exit
{% endif %}
