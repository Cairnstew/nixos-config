; Godot project configuration

[application]
config/name="My Godot Project"
config/description="A game built with Godot Engine"
run/main_scene="res://default/main.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[dotnet]
project/assembly_name="My Godot Project"

[rendering]
renderer/rendering_method="forward_plus"
environment/defaults/default_environment="res://default/default_env.tres"
